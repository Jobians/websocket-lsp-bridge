{
  "name": "ace-linters",
  "author": "Azat Alimov <mkslanc@gmail.com>",
  "version": "2.2.0",
  "scripts": {
    "clean": "rimraf build",
    "postbuild": "node postbuild.js",
    "build:yaml-language-server": "cd ../yaml-language-server-esbuild && npm run build",
    "build:eslint-linter-bundle": "cd ../eslint-linter-bundle && npm run build",
    "build:dependencies": "npm run build:yaml-language-server && npm run build:eslint-linter-bundle",
    "build": "npm run build:dependencies && node build.mjs",
    "build-dev": "npm run build:dependencies && node build.mjs --dev",
    "test:unit": "mocha --exit",
    "test": "npm run test:unit",
    "test:coverage": "nyc npm run test",
    "start-server": "http-server build --cors=\"*\"",
    "generate-typescript-service": "node tools/generate-typescript-service.js"
  },
  "dependencies": {
    "vscode-languageserver-protocol": "^3.17.5",
    "vscode-languageserver-textdocument": "^1.0.12",
    "vscode-languageserver-types": "^3.17.5"
  },
  "devDependencies": {
    "vite": "^8.0.0",
    "vite-plugin-node-polyfills": "^0.25.0",
    "rimraf": "^5.0.0",
    "vscode-html-languageservice": "^5.4.0",
    "vscode-css-languageservice": "^6.3.10",
    "vscode-json-languageservice": "^5.7.2",
    "luaparse": "^0.3.1",
    "marked": "^18.0.0",
    "dompurify": "3.4.0",
    "vscode-ws-jsonrpc": "^3.4.0",
    "htmlhint": "^1.9.2",
    "@xml-tools/constraints": "^1.1.1",
    "@xml-tools/parser": "^1.0.11",
    "@xml-tools/ast": "^5.0.5",
    "@xml-tools/simple-schema": "^3.0.5",
    "vscode-uri": "^3.1.0",
    "@istanbuljs/nyc-config-typescript": "^1.0.2",
    "@types/mocha": "^5.2.7",
    "@types/chai": "^4.3.4",
    "@types/eslint": "^8.21.1",
    "chai": "^4.3.7",
    "mocha": "^10.2.0",
    "nyc": "^15.1.0",
    "ts-node": "^10.9.1",
    "http-server": "^14.1.1",
    "dts-bundle-generator": "^9.5.1",
    "ace-code": "^1.39.0",
    "ace-builds": "^1.39.0",
    "php-parser": "^3.4.0"
  },
  "main": "build/ace-linters.js",
  "files": [
    "build"
  ],
  "repository": {
    "url": "https://github.com/mkslanc/ace-linters"
  },
  "nyc": {
    "extends": "@istanbuljs/nyc-config-typescript",
    "all": false,
    "exclude": [
      "build/*.*",
      "tests/*.*",
      "coverage/**/*.*"
    ],
    "reporter": [
      "html",
      "lcov",
      "text",
      "text-summary"
    ],
    "report-dir": "coverage"
  },
  "license": "MIT",
  "keywords": [
    "language server protocol",
    "lsp",
    "language client",
    "ace-editor",
    "linting",
    "code-completion",
    "code-formatting",
    "error-checking",
    "intellisense"
  ]
}
